---
import AboutSection from '../components/landing/AboutSection.astro'
import AppointmentSection from '../components/landing/AppointmentSection.astro'
import FloatingCta from '../components/landing/FloatingCta.astro'
import HeroSection from '../components/landing/HeroSection.astro'
import ServicesShowcase from '../components/landing/ServicesShowcase.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import {mapLandingToViewModel} from '../lib/landing/mapper'
import {createSeo} from '../lib/seo'
import {getLandingPage, getSiteSettings} from '../lib/sanity/api'

const [landing, siteSettings] = await Promise.all([getLandingPage(), getSiteSettings()])

if (!landing) {
  throw new Error('No existe documento landingPage en Sanity. Ejecuta el seed para cargar contenido inicial.')
}

const seo = createSeo({
  title: landing.seoTitle,
  description: landing.seoDescription,
  fallbackTitle: landing.siteTitle || siteSettings?.defaultSeoTitle || 'Landing page',
  fallbackDescription:
    landing.siteDescription || siteSettings?.defaultSeoDescription || 'Sitio profesional construido con Astro + Sanity',
})

const vm = mapLandingToViewModel(landing)
const siteTitle = siteSettings?.siteName || vm.siteTitle || 'Angel'
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  siteTitle={siteTitle}
  footerText={vm.footerText}
  contactEmail={vm.contactEmail}
  contactWhatsApp={vm.contactWhatsApp}
>
  <HeroSection hero={vm.hero} />
  <ServicesShowcase services={vm.services} />
  <AboutSection about={vm.about} />
  <AppointmentSection appointment={vm.appointment} />
  <FloatingCta cta={vm.floatingCta} />
</BaseLayout>
