---
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sanity Login Callback</title>
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        background: #0d1117;
        color: #e6edf3;
      }
      .card {
        max-width: 640px;
        padding: 1.25rem 1.5rem;
        border: 1px solid #30363d;
        border-radius: 12px;
        background: #161b22;
      }
      p { margin: 0.4rem 0; }
      .ok { color: #3fb950; }
      .error { color: #f85149; }
    </style>
  </head>
  <body>
    <div class="card">
      <p id="status">Completando autenticación de Sanity...</p>
      <p id="detail"></p>
    </div>

    <script>
      const statusEl = document.getElementById('status');
      const detailEl = document.getElementById('detail');
      const params = new URLSearchParams(window.location.search);
      const url = params.get('url');

      if (!url) {
        statusEl.textContent = 'No se encontró la URL de autenticación.';
        statusEl.className = 'error';
      } else {
        fetch(url, {credentials: 'include'})
          .then(async (res) => {
            if (!res.ok) {
              throw new Error(`Respuesta no válida: ${res.status}`);
            }
            statusEl.textContent = 'Autenticación completada.';
            statusEl.className = 'ok';
            detailEl.textContent = 'Puedes volver a la terminal.';
            setTimeout(() => window.close(), 1200);
          })
          .catch((err) => {
            statusEl.textContent = 'No se pudo completar la autenticación.';
            statusEl.className = 'error';
            detailEl.textContent = String(err?.message || err);
          });
      }
    </script>
  </body>
</html>
