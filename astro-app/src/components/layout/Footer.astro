---
interface Props {
  footerText?: string
  contactEmail?: string
  contactWhatsApp?: string
}

const {footerText, contactEmail, contactWhatsApp} = Astro.props
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p>{footerText || 'Contenido administrado en Sanity Studio.'}</p>
    <div class="footer-links">
      {contactEmail && <a href={`mailto:${contactEmail}`}>{contactEmail}</a>}
      {contactWhatsApp && <a href={contactWhatsApp}>WhatsApp</a>}
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    border-top: 1px solid var(--line);
    padding: 1.5rem 0 2rem;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .footer-inner p {
    margin: 0;
  }

  .footer-links {
    display: flex;
    gap: 1rem;
  }

  @media (min-width: 760px) {
    .footer-inner {
      align-items: center;
      justify-content: space-between;
      flex-direction: row;
    }
  }
</style>
