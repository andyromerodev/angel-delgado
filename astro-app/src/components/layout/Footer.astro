---
interface Props {
  footerText?: string
  contactEmail?: string
  contactWhatsApp?: string
}

const {footerText, contactEmail, contactWhatsApp} = Astro.props
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <p class="brand">Dra. Erislaine Tamayo</p>
      <p>{footerText || 'Especialista en Otorrinolaringología y Cirugía Plástica Facial en Tarapoto.'}</p>
    </div>
    <div class="footer-links">
      <a href="/#inicio">Inicio</a>
      <a href="/#servicios">Servicios</a>
      <a href="/#sobre-mi">Sobre Mí</a>
      <a href="/#agendar">Agendar</a>
    </div>
    <div class="footer-links">
      {contactEmail && <a href={`mailto:${contactEmail}`}>{contactEmail}</a>}
      {contactWhatsApp && <a href={contactWhatsApp}>WhatsApp</a>}
      <a href="/blog">Blog</a>
      <a href="/studio">Panel</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 0;
    padding: 3.2rem 0;
    background: var(--surface-container-low);
  }

  .footer-grid {
    display: grid;
    gap: 1.4rem;
    color: var(--on-surface-variant);
    font-size: 0.9rem;
  }

  p {
    margin: 0;
  }

  .brand {
    color: var(--primary);
    font-weight: 800;
    font-family: var(--font-headline);
    margin: 0 0 0.45rem;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .footer-links a {
    text-decoration: none;
  }

  @media (min-width: 900px) {
    .footer-grid {
      grid-template-columns: 1.3fr 1fr 1fr;
      align-items: start;
    }
  }
</style>
