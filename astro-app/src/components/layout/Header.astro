---
interface Props {
  siteTitle: string
}

const {siteTitle} = Astro.props
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand">{siteTitle}</a>
    <nav class="nav" aria-label="Principal">
      <a href="/">Inicio</a>
      <a href="/blog">Blog</a>
      <a href="/studio">Panel</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(8px);
    background: color-mix(in srgb, var(--bg) 85%, white 15%);
    border-bottom: 1px solid var(--line);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 68px;
    gap: 1rem;
  }

  .brand {
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: 0.01em;
    text-decoration: none;
  }

  .nav {
    display: flex;
    gap: 1rem;
    font-size: 0.92rem;
    color: var(--muted);
  }

  .nav a {
    text-decoration: none;
  }
</style>
