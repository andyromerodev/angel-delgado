---
interface Props {
  siteTitle: string
}

const {siteTitle} = Astro.props
---

<header class="site-header" data-header-root>
  <div class="container header-inner">
    <div class="brand-group">
      <button
        class="menu-toggle"
        type="button"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-menu-toggle
      >
        <span class="menu-glyph" aria-hidden="true"></span>
      </button>
      <a href="/" class="brand">{siteTitle}</a>
    </div>

    <nav class="nav-primary" aria-label="Principal">
      <a href="/#inicio">Inicio</a>
      <a href="/#servicios">Servicios</a>
      <a href="/#sobre-mi">Sobre Mí</a>
      <a href="/#agendar">Agendar</a>
    </nav>

    <nav class="nav-secondary" aria-label="Secundaria">
      <a href="/blog">Blog</a>
      <a href="/studio">Panel</a>
    </nav>

    <span class="mobile-avatar" aria-hidden="true">ET</span>
  </div>

  <div id="mobile-menu" class="mobile-menu" hidden data-mobile-menu>
    <nav class="mobile-menu-nav" aria-label="Menú móvil">
      <a href="/#inicio">Inicio</a>
      <a href="/#servicios">Servicios</a>
      <a href="/#sobre-mi">Sobre Mí</a>
      <a href="/#agendar">Agendar</a>
      <a href="/blog">Blog</a>
      <a href="/studio">Panel</a>
    </nav>
  </div>
</header>

<script is:inline>
  const headerRoots = document.querySelectorAll('[data-header-root]')

  headerRoots.forEach((root) => {
    const toggle = root.querySelector('[data-menu-toggle]')
    const menu = root.querySelector('[data-mobile-menu]')
    if (!(toggle instanceof HTMLButtonElement) || !(menu instanceof HTMLElement)) return

    const closeMenu = () => {
      toggle.setAttribute('aria-expanded', 'false')
      menu.hidden = true
      document.body.classList.remove('mobile-menu-open')
    }

    const openMenu = () => {
      toggle.setAttribute('aria-expanded', 'true')
      menu.hidden = false
      document.body.classList.add('mobile-menu-open')
    }

    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true'
      if (isOpen) closeMenu()
      else openMenu()
    })

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu)
    })

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeMenu()
    })

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 920) closeMenu()
    })
  })
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 12;
    backdrop-filter: blur(8px);
    background: color-mix(in srgb, var(--surface) 86%, white 14%);
    border-bottom: 1px solid color-mix(in srgb, var(--outline-variant) 30%, transparent);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 72px;
    gap: 1rem;
    padding-top: 0.45rem;
    padding-bottom: 0.45rem;
  }

  .brand-group {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  .menu-toggle {
    display: none;
    width: 2rem;
    height: 2rem;
    border: 0;
    background: transparent;
    padding: 0;
    cursor: pointer;
    align-items: center;
    justify-content: center;
  }

  .menu-glyph {
    width: 1rem;
    height: 1rem;
    position: relative;
    display: block;
  }

  .menu-glyph::before,
  .menu-glyph::after {
    content: '';
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--primary);
    border-radius: 999px;
  }

  .menu-glyph::before {
    top: 2px;
    box-shadow: 0 5px 0 0 var(--primary);
  }

  .menu-glyph::after {
    top: 12px;
    width: 70%;
  }

  .brand {
    font-size: 1.02rem;
    font-weight: 800;
    letter-spacing: 0.01em;
    text-decoration: none;
    color: var(--primary);
    font-family: var(--font-headline);
  }

  .nav-primary,
  .nav-secondary {
    display: flex;
    gap: 0.85rem;
    font-size: 0.86rem;
    color: var(--muted);
    align-items: center;
  }

  .nav-primary a,
  .nav-secondary a {
    text-decoration: none;
    font-weight: 600;
  }

  .nav-primary a {
    color: var(--primary);
  }

  .nav-secondary a {
    color: var(--on-surface-variant);
  }

  .mobile-avatar {
    display: none;
    width: 1.9rem;
    height: 1.9rem;
    border-radius: 999px;
    background: var(--surface-container-highest);
    color: var(--on-surface-variant);
    font-size: 0.62rem;
    font-weight: 800;
    font-family: var(--font-headline);
    align-items: center;
    justify-content: center;
    letter-spacing: 0.06em;
  }

  .mobile-menu {
    display: none;
  }

  .mobile-menu[hidden] {
    display: none !important;
  }

  @media (max-width: 919px) {
    .site-header {
      backdrop-filter: blur(12px);
      background: color-mix(in srgb, var(--surface) 80%, white 20%);
    }

    .header-inner {
      min-height: 62px;
      gap: 0.65rem;
    }

    .menu-toggle,
    .mobile-avatar {
      display: inline-flex;
    }

    .brand {
      font-size: clamp(1.55rem, 5vw, 2.25rem);
      letter-spacing: -0.015em;
    }

    .nav-primary,
    .nav-secondary {
      display: none;
    }

    .mobile-menu {
      display: block;
      position: fixed;
      inset: 62px 0 auto 0;
      z-index: 11;
      padding: 0.6rem 0;
      background: color-mix(in srgb, var(--surface) 88%, white 12%);
      border-bottom: 1px solid color-mix(in srgb, var(--outline-variant) 30%, transparent);
      backdrop-filter: blur(14px);
    }

    .mobile-menu-nav {
      width: min(1120px, 94vw);
      margin: 0 auto;
      background: var(--surface-container-lowest);
      border-radius: 1rem;
      padding: 0.4rem;
      display: grid;
      gap: 0.2rem;
      box-shadow: var(--shadow-soft);
    }

    .mobile-menu-nav a {
      text-decoration: none;
      color: var(--primary);
      font-family: var(--font-headline);
      font-weight: 700;
      font-size: 1.05rem;
      padding: 0.65rem 0.7rem;
      border-radius: 0.7rem;
      min-height: 44px;
      display: flex;
      align-items: center;
    }

    .mobile-menu-nav a:hover {
      background: var(--surface-container-low);
    }
  }

  :global(body.mobile-menu-open) {
    overflow: hidden;
  }
</style>
