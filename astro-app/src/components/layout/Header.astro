---
interface Props {
  siteTitle: string
}

const {siteTitle} = Astro.props
---

<header class="site-header" data-header-root>
  <div class="container header-inner">
    <div class="brand-group">
      <a href="/" class="brand">{siteTitle}</a>
    </div>

    <nav class="nav-primary" aria-label="Principal">
      <a href="/#inicio">Inicio</a>
      <a href="/#servicios">Servicios</a>
      <a href="/#sobre-mi">Sobre Mí</a>
      <a href="/#agendar">Agendar</a>
    </nav>

    <nav class="nav-secondary" aria-label="Secundaria">
      <a href="/blog">Blog</a>
      <a href="/studio">Panel</a>
    </nav>
  </div>
</header>

<div class="mobile-nav-wrap">
  <p class="mobile-swipe-hint" data-swipe-hint>Desliza</p>
  <nav class="mobile-button-nav" aria-label="Navegación rápida" data-mobile-button-nav>
    <a href="/#inicio">Inicio</a>
    <a href="/#servicios">Servicios</a>
    <a href="/#sobre-mi">Sobre Mí</a>
    <a href="/#agendar">Agendar</a>
    <a href="/blog">Blog</a>
    <a href="/studio">Panel</a>
  </nav>
</div>

<script is:inline>
  const mobileNavs = document.querySelectorAll('[data-mobile-button-nav]')

  mobileNavs.forEach((nav) => {
    if (!(nav instanceof HTMLElement)) return

    const hint = nav.parentElement?.querySelector('[data-swipe-hint]')
    if (!(hint instanceof HTMLElement)) return

    const hideHint = () => hint.classList.add('is-hidden')
    const maybeHideHint = () => {
      if (nav.scrollLeft > 8) hideHint()
    }

    if (nav.scrollWidth <= nav.clientWidth + 2) {
      hideHint()
      return
    }

    nav.addEventListener('scroll', maybeHideHint, {passive: true})
    nav.addEventListener('touchmove', maybeHideHint, {passive: true})
    nav.addEventListener('wheel', maybeHideHint, {passive: true})
  })
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 12;
    backdrop-filter: blur(8px);
    background: color-mix(in srgb, var(--surface) 86%, white 14%);
    border-bottom: 1px solid color-mix(in srgb, var(--outline-variant) 30%, transparent);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 72px;
    gap: 1rem;
    padding-top: 0.45rem;
    padding-bottom: 0.45rem;
  }

  .brand-group {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  .brand {
    font-size: 1.02rem;
    font-weight: 800;
    letter-spacing: 0.01em;
    text-decoration: none;
    color: var(--primary);
    font-family: var(--font-headline);
  }

  .nav-primary,
  .nav-secondary {
    display: flex;
    gap: 0.85rem;
    font-size: 0.86rem;
    color: var(--muted);
    align-items: center;
  }

  .nav-primary a,
  .nav-secondary a {
    text-decoration: none;
    font-weight: 600;
  }

  .nav-primary a {
    color: var(--primary);
  }

  .nav-secondary a {
    color: var(--on-surface-variant);
  }

  .mobile-button-nav {
    display: none;
  }

  .mobile-nav-wrap {
    display: none;
  }

  .mobile-swipe-hint {
    display: none;
  }

  @media (max-width: 919px) {
    .site-header {
      backdrop-filter: blur(12px);
      background: color-mix(in srgb, var(--surface) 80%, white 20%);
    }

    .header-inner {
      min-height: 62px;
      gap: 0.65rem;
    }

    .brand {
      font-size: clamp(1.55rem, 5vw, 2.25rem);
      letter-spacing: -0.015em;
    }

    .nav-primary,
    .nav-secondary {
      display: none;
    }

    .mobile-nav-wrap {
      display: block;
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 11;
      pointer-events: none;
      padding: 0 0 0.5rem;
    }

    .mobile-swipe-hint {
      display: block;
      margin: 0 auto 0.32rem;
      width: fit-content;
      font-size: 0.66rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      opacity: 0.78;
      transition: opacity 0.2s ease, transform 0.2s ease;
      animation: swipeHintFloat 1.25s ease-in-out infinite;
      pointer-events: none;
    }

    .mobile-swipe-hint::before,
    .mobile-swipe-hint::after {
      content: '↔';
      display: inline-block;
      margin: 0 0.32rem;
      font-size: 0.64rem;
      opacity: 0.9;
    }

    .mobile-swipe-hint.is-hidden {
      opacity: 0;
      transform: translateY(4px);
      animation: none;
    }

    .mobile-button-nav {
      display: flex;
      margin: 0 auto;
      width: min(94vw, 700px);
      gap: 0.4rem;
      overflow-x: auto;
      padding: 0.45rem;
      border-radius: 999px;
      background: color-mix(in srgb, var(--surface) 92%, white 8%);
      border: 1px solid color-mix(in srgb, var(--outline-variant) 45%, transparent);
      backdrop-filter: blur(12px);
      box-shadow: var(--shadow-soft);
      -webkit-overflow-scrolling: touch;
      pointer-events: auto;
    }

    .mobile-button-nav a {
      flex: 0 0 auto;
      text-decoration: none;
      color: var(--primary);
      font-family: var(--font-body);
      font-weight: 600;
      font-size: 0.9rem;
      padding: 0.5rem 0.8rem;
      border-radius: 999px;
      min-height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--surface-container-lowest);
      border: 1px solid var(--line);
      white-space: nowrap;
    }

    .mobile-button-nav a:hover {
      background: var(--surface-container-low);
    }

    :global(body) {
      padding-bottom: 5.2rem;
    }
  }

  @keyframes swipeHintFloat {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-2px);
    }
  }
</style>
