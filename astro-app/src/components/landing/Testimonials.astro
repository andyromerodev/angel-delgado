---
interface Testimonial {
  name: string
  role?: string
  quote: string
}

interface Props {
  items: Testimonial[]
}

const {items} = Astro.props
---

<section class="container section">
  <h2 class="section-title">Clientes y resultados</h2>
  <div class="grid cols-3">
    {items.map((item) => (
      <figure class="card testimonial">
        <blockquote>“{item.quote}”</blockquote>
        <figcaption>
          <strong>{item.name}</strong>
          {item.role && <span>{item.role}</span>}
        </figcaption>
      </figure>
    ))}
  </div>
</section>

<style>
  .testimonial {
    padding: 1rem;
    margin: 0;
  }

  blockquote {
    margin: 0;
    font-size: 0.98rem;
  }

  figcaption {
    margin-top: 0.9rem;
    display: flex;
    flex-direction: column;
    color: var(--muted);
    font-size: 0.88rem;
  }

  strong {
    color: var(--text);
    margin-bottom: 0.2rem;
  }
</style>
