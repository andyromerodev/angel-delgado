---
interface Item {
  title: string
  description: string
  iconName?: string
}

interface Props {
  title: string
  subtitle?: string
  items: Item[]
  columns?: 2 | 3
}

const {title, subtitle, items, columns = 3} = Astro.props
const colsClass = columns === 2 ? 'cols-2' : 'cols-3'
---

<section class="container section">
  <h2 class="section-title">{title}</h2>
  {subtitle && <p class="section-subtitle">{subtitle}</p>}
  <div class={`grid ${colsClass} cards`}>
    {items.map((item) => (
      <article class="card item-card">
        {item.iconName && <p class="icon">{item.iconName}</p>}
        <h3>{item.title}</h3>
        <p>{item.description}</p>
      </article>
    ))}
  </div>
</section>

<style>
  .cards {
    margin-top: 1rem;
  }

  .item-card {
    padding: 1rem;
  }

  .icon {
    margin: 0 0 0.3rem;
    color: var(--accent);
    font-size: 0.8rem;
    font-weight: 700;
  }

  h3 {
    margin: 0 0 0.45rem;
    line-height: 1.2;
    font-size: 1.05rem;
  }

  p {
    margin: 0;
    color: var(--muted);
  }
</style>
