---
interface FaqItem {
  question: string
  answer: string
}

interface Props {
  items: FaqItem[]
}

const {items} = Astro.props
---

<section class="container section">
  <h2 class="section-title">Preguntas frecuentes</h2>
  <div class="faq-list">
    {items.map((item) => (
      <details class="faq-item card">
        <summary>{item.question}</summary>
        <p>{item.answer}</p>
      </details>
    ))}
  </div>
</section>

<style>
  .faq-list {
    display: grid;
    gap: 0.75rem;
  }

  .faq-item {
    padding: 0.9rem 1rem;
  }

  summary {
    cursor: pointer;
    font-weight: 700;
  }

  p {
    margin: 0.8rem 0 0;
    color: var(--muted);
  }
</style>
