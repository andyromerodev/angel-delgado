---
interface Props {
  title: string
  subtitle?: string
  primaryText?: string
  primaryLink?: string
  secondaryText?: string
  secondaryLink?: string
}

const {title, subtitle, primaryText, primaryLink, secondaryText, secondaryLink} = Astro.props
---

<section class="container section hero">
  <div class="hero-copy">
    <p class="eyebrow">Estrategia digital + ejecución</p>
    <h1>{title}</h1>
    {subtitle && <p class="section-subtitle">{subtitle}</p>}
    <div class="actions">
      {primaryText && primaryLink && (
        <a class="btn btn-primary" href={primaryLink}>
          {primaryText}
        </a>
      )}
      {secondaryText && secondaryLink && (
        <a class="btn btn-ghost" href={secondaryLink}>
          {secondaryText}
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: 2rem;
  }

  .hero-copy {
    background: linear-gradient(110deg, #ffffff, #ecfbf7);
    border: 1px solid var(--line);
    border-radius: calc(var(--radius) + 4px);
    padding: clamp(1.5rem, 4vw, 3rem);
    box-shadow: var(--shadow);
  }

  .eyebrow {
    margin: 0;
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.74rem;
  }

  h1 {
    margin: 0.75rem 0;
    line-height: 1.1;
    font-size: clamp(1.9rem, 4.8vw, 3.4rem);
    letter-spacing: -0.02em;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.2rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.68rem 1.1rem;
    text-decoration: none;
    font-weight: 700;
    border: 1px solid transparent;
    transition: transform 0.2s ease;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn-primary {
    background: var(--accent);
    color: white;
  }

  .btn-ghost {
    border-color: var(--line);
    background: white;
  }
</style>
