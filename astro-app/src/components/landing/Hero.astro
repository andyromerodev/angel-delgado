---
import {imageUrl} from '../../lib/sanity/image'
import type {SanityImage} from '../../lib/sanity/types'

interface Props {
  title: string
  subtitle?: string
  primaryText?: string
  primaryLink?: string
  secondaryText?: string
  secondaryLink?: string
  image?: SanityImage
}

const {title, subtitle, primaryText, primaryLink, secondaryText, secondaryLink, image} = Astro.props

const doctorImageUrl =
  imageUrl(image)?.width(900).height(1080).fit('crop').url() ||
  'https://images.unsplash.com/photo-1559839734-2b71ea197ec2?auto=format&fit=crop&w=900&q=80'
---

<section class="container section hero">
  <div class="hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">Ginecologia integral en Tarapoto, Peru</p>
      <h1>{title}</h1>
      {subtitle && <p class="section-subtitle">{subtitle}</p>}
      <div class="actions">
        {primaryText && primaryLink && (
          <a class="btn btn-primary" href={primaryLink}>
            {primaryText}
          </a>
        )}
        {secondaryText && secondaryLink && (
          <a class="btn btn-ghost" href={secondaryLink}>
            {secondaryText}
          </a>
        )}
      </div>
    </div>

    <div class="hero-photo card">
      <img
        src={doctorImageUrl}
        alt={image?.alt || 'Doctora especialista en ginecologia'}
        loading="eager"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: 1.5rem;
  }

  .hero-grid {
    display: grid;
    gap: 1rem;
    align-items: stretch;
  }

  .hero-copy {
    background: linear-gradient(170deg, #ffffff, #f1f4f5);
    border: 1px solid var(--line);
    border-radius: calc(var(--radius) + 4px);
    padding: clamp(1.25rem, 4vw, 2.75rem);
    box-shadow: var(--shadow);
  }

  .hero-photo {
    overflow: hidden;
    min-height: 280px;
  }

  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
  }

  .eyebrow {
    margin: 0;
    color: #4c5963;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.72rem;
  }

  h1 {
    margin: 0.75rem 0;
    line-height: 1.1;
    font-size: clamp(1.9rem, 4.8vw, 3.1rem);
    letter-spacing: -0.02em;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.2rem;
  }

  .helper-text {
    margin: 0.9rem 0 0;
    color: var(--muted);
    font-size: 0.86rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.68rem 1.1rem;
    text-decoration: none;
    font-weight: 700;
    border: 1px solid transparent;
    transition: transform 0.2s ease;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn-primary {
    background: #0f1720;
    color: white;
  }

  .btn-ghost {
    border-color: var(--line);
    background: white;
  }

  @media (min-width: 860px) {
    .hero-grid {
      grid-template-columns: 1.2fr 0.8fr;
      min-height: 500px;
    }
  }
</style>
