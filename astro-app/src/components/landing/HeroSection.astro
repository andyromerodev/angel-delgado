---
import {imageUrl} from '../../lib/sanity/image'
import type {LandingViewModel} from '../../lib/landing/view-model'

interface Props {
  hero: LandingViewModel['hero']
}

const {hero} = Astro.props
const heroImageUrl =
  imageUrl(hero.image)?.width(900).height(1100).fit('crop').url() ||
  'https://images.unsplash.com/photo-1559839734-2b71ea197ec2?auto=format&fit=crop&w=900&q=80'
---

<section class="section-hero" id="inicio">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="hero-badge">{hero.badge}</p>
      <h1>
        {hero.titlePrefix}<br />
        <span class="text-gradient">{hero.titleHighlight}</span><br />
        {hero.titleSuffix}
      </h1>
      <p class="hero-subtitle">{hero.subtitle}</p>
      <div class="cta-row">
        <a class="btn btn-primary" href={hero.primaryLink}>{hero.primaryText}</a>
        <a class="btn btn-ghost" href={hero.secondaryLink}>{hero.secondaryText}</a>
      </div>
    </div>

    <div class="hero-media">
      <div class="hero-shape" aria-hidden="true"></div>
      <img src={heroImageUrl} alt={hero.image?.alt || 'Dra. Erislaine Tamayo'} loading="eager" />
      <aside class="trust-card">
        <p class="trust-title">{hero.trustCardTitle}</p>
        <p class="trust-subtitle">{hero.trustCardSubtitle}</p>
      </aside>
    </div>
  </div>
</section>

<style>
  .section-hero {
    position: relative;
    background: var(--surface);
    padding: 4.4rem 0 3rem;
    overflow: hidden;
  }

  .hero-grid {
    display: grid;
    gap: 2rem;
    align-items: center;
  }

  .hero-badge {
    margin: 0 0 1rem;
    display: inline-block;
    background: var(--secondary-container);
    color: var(--on-secondary-container);
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 700;
  }

  h1 {
    margin: 0;
    font-family: var(--font-headline);
    font-size: clamp(2.2rem, 8vw, 4.5rem);
    line-height: 1.03;
    letter-spacing: -0.03em;
    color: var(--on-surface);
  }

  .hero-subtitle {
    margin: 1.5rem 0 0;
    max-width: 58ch;
    font-size: clamp(1rem, 2.8vw, 1.2rem);
    color: var(--on-surface-variant);
  }

  .cta-row {
    margin-top: 1.7rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero-media {
    position: relative;
    height: min(74vh, 700px);
    min-height: 350px;
  }

  .hero-shape {
    position: absolute;
    inset: 1.5rem;
    border-radius: 2.8rem;
    background: color-mix(in srgb, var(--primary-fixed) 55%, transparent);
    transform: rotate(-4deg);
  }

  .hero-media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 2.6rem;
    box-shadow: var(--shadow-elevated);
  }

  .trust-card {
    position: absolute;
    left: -0.75rem;
    bottom: -1rem;
    background: var(--surface-container-lowest);
    border-radius: 1rem;
    padding: 0.9rem 1rem;
    box-shadow: var(--shadow-soft);
    max-width: 240px;
  }

  .trust-title {
    margin: 0;
    font-size: 0.85rem;
    font-weight: 700;
  }

  .trust-subtitle {
    margin: 0.2rem 0 0;
    color: var(--on-surface-variant);
    font-size: 0.78rem;
  }

  @media (max-width: 919px) {
    .section-hero {
      min-height: 86dvh;
      padding: 0;
      background: var(--surface-container-low);
    }

    .hero-grid {
      position: relative;
      min-height: 86dvh;
      align-items: end;
      gap: 0;
    }

    .hero-copy {
      position: relative;
      z-index: 2;
      padding: 0 0 2.2rem;
      max-width: 28rem;
    }

    h1 {
      font-size: clamp(2.35rem, 8vw, 3.45rem);
      line-height: 1.02;
    }

    .hero-subtitle {
      max-width: 26rem;
      line-height: 1.5;
    }

    .hero-media {
      position: absolute;
      inset: 0;
      height: 100%;
      min-height: 100%;
      z-index: 0;
    }

    .hero-media::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        color-mix(in srgb, var(--surface) 97%, transparent) 14%,
        color-mix(in srgb, var(--surface) 80%, transparent) 44%,
        transparent 72%
      );
      z-index: 1;
    }

    .hero-media img {
      border-radius: 0;
      box-shadow: none;
      object-position: center top;
    }

    .hero-shape,
    .trust-card {
      display: none;
    }

    .cta-row {
      display: grid;
      gap: 0.6rem;
      margin-top: 1.25rem;
    }
  }

  @media (min-width: 920px) {
    .hero-grid {
      grid-template-columns: 1.08fr 0.92fr;
      gap: 3.25rem;
    }

    .section-hero {
      padding: 5.5rem 0 3.5rem;
    }

    .hero-media {
      min-height: 420px;
    }
  }

  @media (max-width: 639px) {
    h1 {
      font-size: clamp(2rem, 10vw, 2.8rem);
    }

    .hero-badge {
      margin-bottom: 0.7rem;
      font-size: 0.64rem;
    }

    .hero-subtitle {
      font-size: 1rem;
      max-width: 24rem;
      margin-top: 1rem;
    }

    .section-hero,
    .hero-grid {
      min-height: 82dvh;
    }

    .hero-copy {
      padding-bottom: 1.6rem;
    }
  }
</style>
