---
import type {LandingViewModel} from '../../lib/landing/view-model'

interface Props {
  cta?: LandingViewModel['floatingCta']
}

const {cta} = Astro.props
---

{
  cta && (
    <a class="floating-cta" href={cta.link} aria-label={cta.label}>
      <span>{cta.iconName}</span>
    </a>
  )
}

<style>
  .floating-cta {
    position: fixed;
    right: 1rem;
    bottom: calc(1rem + env(safe-area-inset-bottom));
    z-index: 25;
    width: 3.2rem;
    height: 3.2rem;
    border-radius: 999px;
    display: grid;
    place-items: center;
    text-decoration: none;
    background: var(--secondary-container);
    color: var(--on-secondary-container);
    box-shadow: var(--shadow-soft);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
  }

  @media (max-width: 919px) {
    .floating-cta {
      width: 3rem;
      height: 3rem;
      right: 0.85rem;
      bottom: calc(0.85rem + env(safe-area-inset-bottom));
      background: var(--tertiary);
      color: var(--on-primary);
      font-size: 0.64rem;
    }
  }

  .floating-cta:hover {
    transform: translateY(-1px);
  }

  @media (min-width: 920px) {
    .floating-cta {
      right: 1.8rem;
      bottom: calc(1.8rem + env(safe-area-inset-bottom));
    }
  }
</style>
