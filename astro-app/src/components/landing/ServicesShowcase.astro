---
import {imageUrl} from '../../lib/sanity/image'
import type {LandingViewModel} from '../../lib/landing/view-model'

interface Props {
  services: LandingViewModel['services']
}

const {services} = Astro.props
---

<section class="section-services" id="servicios">
  <div class="container">
    <header class="section-heading center">
      <p class="eyebrow">{services.eyebrow}</p>
      <h2>{services.title}</h2>
    </header>

    <div class="services-grid">
      {services.cards.map((card) => (
        <article class:list={['service-card', `variant-${card.variant}`]}>
          {card.variant === 'feature' && card.label && <p class="chip">{card.label}</p>}
          {card.iconName && card.variant !== 'feature' && <p class="icon">{card.iconName}</p>}
          <h3>{card.title}</h3>
          <p>{card.description}</p>
          {card.bullets.length > 0 && (
            <ul>
              {card.bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
          )}
          {card.image && (
            <img
              src={imageUrl(card.image)?.width(500).height(500).fit('crop').url()}
              alt={card.image.alt || card.title}
              loading="lazy"
            />
          )}
          {card.ctaText && card.ctaLink && (
            <a class:list={['inline-link', card.variant === 'accent' && 'on-accent']} href={card.ctaLink}>
              {card.ctaText}
            </a>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .section-services {
    background: var(--surface-container-low);
    padding: 3.6rem 0;
  }

  .services-grid {
    display: grid;
    gap: 1rem;
    margin-top: 2rem;
  }

  .service-card {
    border-radius: 1.6rem;
    background: var(--surface-container-lowest);
    padding: 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    min-height: 0;
  }

  .service-card h3 {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.15;
    letter-spacing: -0.015em;
  }

  .service-card p {
    margin: 0;
    color: var(--on-surface-variant);
  }

  .service-card ul {
    margin: 0;
    padding-left: 1rem;
    color: var(--on-surface);
    display: grid;
    gap: 0.35rem;
    font-size: 0.93rem;
  }

  .chip {
    margin: 0;
    width: fit-content;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    background: var(--tertiary-fixed);
    color: var(--on-tertiary-fixed);
    padding: 0.3rem 0.65rem;
    border-radius: 999px;
  }

  .icon {
    margin: 0;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--primary);
    font-weight: 700;
  }

  .inline-link {
    margin-top: auto;
    text-decoration: none;
    font-weight: 700;
    color: var(--primary);
  }

  .variant-feature img {
    border-radius: 1rem;
    width: 100%;
    max-width: 280px;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  .variant-accent {
    background: var(--primary-container);
  }

  .variant-accent h3,
  .variant-accent p {
    color: var(--on-primary);
  }

  .variant-accent .on-accent {
    color: var(--on-primary);
  }

  @media (max-width: 919px) {
    .section-services {
      background: var(--surface);
      padding: var(--mobile-section-space) 0;
    }

    .section-heading.center {
      text-align: left;
    }

    .services-grid {
      gap: 0.8rem;
      margin-top: 1.35rem;
    }

    .service-card {
      border-radius: var(--radius-mobile-card);
      padding: 1rem 1rem 1.05rem;
      box-shadow: none;
      min-height: 0;
    }

    .variant-feature {
      background: var(--surface-container-lowest);
    }

    .variant-standard {
      background: var(--surface-container-low);
    }

    .variant-accent {
      border-radius: var(--radius-mobile-card);
    }
  }

  @media (min-width: 860px) {
    .section-services {
      padding: 4.5rem 0;
    }

    .services-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      grid-auto-rows: minmax(220px, auto);
    }

    .variant-feature {
      grid-column: span 2;
      display: grid;
      grid-template-columns: 1fr 220px;
      align-items: center;
      gap: 1.2rem;
    }

    .variant-accent {
      grid-column: span 2;
    }
  }

  @media (max-width: 639px) {
    .service-card {
      border-radius: 1.25rem;
      padding: 1.1rem;
    }

    .service-card h3 {
      font-size: 1.2rem;
    }
  }
</style>
